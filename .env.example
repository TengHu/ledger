# Copy to .env and fill in your values.
# Get these from https://dashboard.plaid.com/team/keys after signing up.

PLAID_CLIENT_ID=
PLAID_SECRET=

# Environment: sandbox | development | production
# - sandbox: free, fake data, use for testing the install
# - production: real banks. Free tier covers ~100 items, plenty for personal use.
PLAID_ENV=production

# Local Flask server port for one-time Plaid Link auth
LEDGER_PORT=8765

# DB path (default: ~/Code/ledger/db.sqlite)
# LEDGER_DB_PATH=

# Stale threshold in minutes — how long cached data stays valid before
# automatic refresh on next query (default: 60)
LEDGER_STALE_MINUTES=60
